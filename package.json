{
  "name": "llm-diagrams",
  "version": "0.1.0",
  "type": "module",
  "description": "Automated architecture diagram generator",
  "scripts": {
    "test": "vitest run",
    "docs:diagram": "tsx scripts/generate-architecture-diagram.ts",
    "docs:diagram:static": "tsx scripts/generate-architecture-diagram.ts --mode static",
    "docs:diagram:full": "tsx scripts/generate-architecture-diagram.ts --mode full",
    "docs:diagram:subscription": "tsx scripts/generate-architecture-diagram.ts --mode subscription",
    "docs:diagram:openai": "tsx scripts/generate-architecture-diagram.ts --mode openai",
    "docs:diagram:openrouter": "tsx scripts/generate-architecture-diagram.ts --mode openrouter",
    "docs:diagram:llmapi": "tsx scripts/generate-architecture-diagram.ts --mode llmapi",
    "tui": "tsx scripts/archdiagram/tui/index.tsx"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "latest",
    "@excalidraw/mermaid-to-excalidraw": "^2.1.1",
    "@inkjs/ui": "^2.0.0",
    "@mermaid-js/mermaid-cli": "latest",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dependency-cruiser": "latest",
    "dompurify": "^3.3.3",
    "elkjs": "latest",
    "ink": "^6.8.0",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-morph": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^2.0.0",
    "zod": "latest"
  }
}
